# ==========================================
# TDK AUTOMATED BOT ENVIRONMENT VARIABLES
# ==========================================

# NVIDIA NIM CONFIG
NVIDIA_NIM_API_KEY=your_nvidia_nim_api_key_here
NIM_MODEL=meta/llama3-70b-instruct
NIM_URL=https://integrate.api.nvidia.com/v1/chat/completions

# VANTAGE MT5 CREDENTIALS
MT5_LOGIN=12345678
MT5_PASSWORD=your_vantage_password_here
MT5_SERVER=Vantage-Demo

# TRADING PARAMETERS
SYMBOL=XAUUSD
TIMEFRAME=M15       # M1, M5, M15, M30, H1, H4, D1
DRY_RUN=True        # Set to False to execute real trades

# RISK PARAMETERS
RISK_PCT=0.01       # 1% risk per trade
MAX_DAILY_DRAWDOWN_PCT=0.03
ATR_SL_MULTIPLIER=1.5
